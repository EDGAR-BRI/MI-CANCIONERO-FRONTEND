---
import Layout from "../layouts/LoginLayout.astro";
import "../styles/global.css";
---

<Layout title="Nueva Contrasena - Cancionero">
    <div class="w-full flex-1 flex items-center justify-center p-4">
        <section class="w-full max-w-md bg-bg-secondary p-8 rounded-xl shadow-lg border border-white/5">
            <h1 class="text-2xl font-bold text-accent-main mb-3 text-center">Crear Nueva Contrasena</h1>
            <p class="text-sm text-text-secondary mb-6 text-center">
                Ingresa tu nueva contrasena para completar la recuperacion.
            </p>

            <form id="resetForm" class="space-y-6" method="POST">
                <div>
                    <label for="password" class="block text-sm font-medium text-text-secondary mb-2">Nueva Contrasena</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        minlength="6"
                        required
                        class="w-full bg-bg-main border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-main transition-colors"
                        placeholder="Minimo 6 caracteres"
                    />
                </div>

                <div>
                    <label for="confirmPassword" class="block text-sm font-medium text-text-secondary mb-2">Confirmar Contrasena</label>
                    <input
                        type="password"
                        id="confirmPassword"
                        name="confirmPassword"
                        minlength="6"
                        required
                        class="w-full bg-bg-main border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-main transition-colors"
                        placeholder="Repite la contrasena"
                    />
                </div>

                <button
                    id="submitBtn"
                    type="submit"
                    class="w-full bg-accent-main text-white font-bold py-3 rounded-lg hover:bg-accent-secondary transition-transform transform active:scale-95"
                >
                    Actualizar Contrasena
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-text-secondary">
                <a href="/login" class="text-accent-main hover:underline">Volver al login</a>
            </p>
        </section>
    </div>
</Layout>

<script>
    import { actions } from "astro:actions";
    import { showAlert, showSuccessToast } from "../utils/alerts";

    const form = document.getElementById("resetForm") as HTMLFormElement;
    const btn = document.getElementById("submitBtn") as HTMLButtonElement;

    const hash = new URLSearchParams(window.location.hash.replace(/^#/, ""));
    const accessToken = hash.get("access_token");

    if (!accessToken) {
        showAlert({
            icon: "error",
            title: "Enlace invalido",
            text: "El enlace de recuperacion es invalido o expiro.",
        });
    }

    if (form && btn) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const password = String(formData.get("password") || "");
            const confirmPassword = String(formData.get("confirmPassword") || "");

            if (password !== confirmPassword) {
                showAlert({ icon: "error", title: "Error", text: "Las contrasenas no coinciden." });
                return;
            }

            if (!accessToken) return;

            const originalBtnContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = "Actualizando...";

            try {
                const { data, error } = await actions.resetPassword({
                    accessToken,
                    newPassword: password,
                });

                if (!error && data?.success) {
                    await showSuccessToast("Contrasena actualizada. Ahora puedes iniciar sesion.");
                    window.location.href = "/login";
                    return;
                }

                showAlert({
                    icon: "error",
                    title: "No se pudo actualizar",
                    text: error?.message || "Intenta nuevamente",
                });
            } catch (err) {
                showAlert({
                    icon: "error",
                    title: "Error",
                    text: "No se pudo conectar con el servidor",
                });
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalBtnContent;
            }
        });
    }
</script>
